{
  "title": "Ebbefos Home Battery",
  "config": {
    "step": {
      "user": {
        "description": "This integration uses the API that powers the Ebbefos energy app. \nTo use the api, you must log in to the Ebbefos webapp using a web browser, extract the refresh token, and paste it here. This will add all \"sites\" (installations) you user has access to, to Home Assistant. \nSee the README on https://github.com/AThomsen/home-assistant_ebbefos-home-battery for how to extract the token from your browser.",
        "data": {
          "refresh_token": "Refresh token"
        }
      }
    },
    "error": {
      "cannot_connect": "[%key:common::config_flow::error::cannot_connect%]",
      "invalid_auth": "[%key:common::config_flow::error::invalid_auth%]",
      "unknown": "[%key:common::config_flow::error::unknown%]"
    },
    "abort": {
      "already_configured": "[%key:common::config_flow::abort::already_configured_device%]"
    }
  },
  "entity": {
    "sensor": {
      "battery_power_flow": {
        "name": "Battery power flow"
      },
      "pv_power": {
        "name": "PV power"
      },
      "power_consumption": {
        "name": "Power consumption"
      },
      "battery_soc": {
        "name": "Battery level"
      },
      "grid_power_flow": {
        "name": "Grid power flow"
      },
      "grid_energy_imported_today": {
        "name": "Grid energy imported today"
      },
      "grid_energy_exported_today": {
        "name": "Grid energy exported today"
      },
      "battery_energy_charged_today": {
        "name": "Battery energy charged today"
      },
      "battery_energy_discharged_today": {
        "name": "Battery energy discharged today"
      },
      "pv_energy_today": {
        "name": "PV energy today"
      },
      "energy_consumption_today": {
        "name": "Energy consumption today"
      },
      "cost_today": {
        "name": "Cost today"
      },
      "earnings_today": {
        "name": "Earnings today"
      },
      "savings_today": {
        "name": "Savings today"
      },
      "total_savings_today": {
        "name": "Total savings today"
      },
      "cost_without_solar_and_battery_today": {
        "name": "Cost without solar and battery today"
      },
      "cost_without_battery_today": {
        "name": "Cost without battery today"
      },
      "battery_status": {
        "state": {
          "Unspecified": "Unspecified",
          "Offline": "Offline",
          "Running": "Running",
          "Initializing": "Initializing",
          "Error": "Error",
          "Maintenance": "Maintenance",
          "Sleep": "Sleep"
        }
      }
    }
  }
}